---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import {
  useTranslations,
  switchLocalePath,
  type Locale,
  type AltPaths,
} from '../i18n/utils';

interface Props {
  lang: Locale;
  title: string;
  description: string;
  ogImage?: string;
  /** Paths of this page in both languages. Defaults to the mechanical
   *  `/x` <-> `/en/x` mapping — pass explicitly when slugs differ per
   *  language (blog articles), so hreflang and the toggle stay correct. */
  altPaths?: AltPaths;
}

const {
  lang,
  title,
  description,
  ogImage = '/og-image.png',
  altPaths = {
    fr: switchLocalePath(Astro.url, 'fr'),
    en: switchLocalePath(Astro.url, 'en'),
  },
} = Astro.props;
const t = useTranslations(lang);

// Absolute URLs are required for canonical / OG / sitemap correctness.
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);
const frUrl = new URL(altPaths.fr, Astro.site);
const enUrl = new URL(altPaths.en, Astro.site);
const ogLocale = t.meta.og_locale;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Preload self-hosted variable fonts (same-origin, crossorigin required for fonts). -->
    <link
      rel="preload"
      href="/fonts/inter-latin-wght-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/jetbrains-mono-latin-wght-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="alternate" hreflang="fr" href={frUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={frUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body>
    <a class="skip-link" href="#contenu">{t.nav.skip}</a>
    <div class="topline" aria-hidden="true"></div>
    <Header lang={lang} altPaths={altPaths} />
    <main id="contenu">
      <slot />
    </main>
    <Footer lang={lang} altPaths={altPaths} />
  </body>
</html>
