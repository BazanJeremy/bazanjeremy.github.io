---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../../i18n/utils';

const lang = 'en' as const;
const t = useTranslations(lang);
const blog = t.blog;

const df = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const posts = (
  await getCollection('blog', (e) => e.data.lang === lang && !e.data.draft)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  lang={lang}
  title={blog.index_title}
  description={blog.index_description}
>
  <section class="section">
    <div class="wrap">
      <span class="kicker" aria-hidden="true"></span>
      <h1 class="text-thesis font-bold text-fg">{blog.heading}</h1>
      <p class="mt-3 max-w-prose text-muted">{blog.lead}</p>

      {
        posts.length === 0 ? (
          <p class="mt-10 text-muted">{blog.empty}</p>
        ) : (
          <ul class="mt-10 grid gap-4 sm:grid-cols-2">
            {posts.map((post) => (
              <li>
                <a
                  href={`/en/blog/${post.data.slug}`}
                  class="group card-lift flex h-full flex-col rounded-xl border border-line bg-surface p-5 hover:border-accent"
                >
                  <span class="flex items-center gap-2">
                    <span class="chip">{post.data.tag}</span>
                  </span>
                  <time
                    datetime={post.data.date.toISOString()}
                    class="mt-3 font-mono text-xs text-muted"
                  >
                    {df.format(post.data.date)}
                  </time>
                  <span class="mt-2 font-medium leading-snug text-fg transition-colors group-hover:text-accent">
                    {post.data.title}
                  </span>
                  <span class="mt-2 text-sm leading-relaxed text-muted">
                    {post.data.excerpt}
                  </span>
                  <span class="mt-4 text-sm font-semibold text-accent">
                    {blog.read_more}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>
</BaseLayout>
