---
import { useTranslations, type Locale } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const stack = t.stack;
---

<section id={stack.id}>
  <h2>{stack.heading}</h2>
  <ul>
    {stack.items.map((item) => <li>{item}</li>)}
  </ul>
</section>
