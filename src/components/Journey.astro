---
import { useTranslations, type Locale } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const journey = t.journey;
---

<section id={journey.id} class="section section-alt border-t border-line">
  <div class="wrap">
    <span class="kicker" aria-hidden="true"></span>
    <h2 class="text-heading font-semibold text-fg">{journey.heading}</h2>

    <ol class="mt-10 space-y-9 border-l border-line">
      {
        journey.items.map((item) => (
          <li class="reveal relative pl-6">
            <span
              aria-hidden="true"
              class="absolute -left-[5px] top-1.5 h-2.5 w-2.5 rounded-full border-2 border-surface bg-accent"
            />
            <p class="font-semibold text-fg">{item.label}</p>
            <p class="mt-1 max-w-prose text-sm leading-relaxed text-muted">
              {item.text}
            </p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
